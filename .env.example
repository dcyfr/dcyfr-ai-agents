# DCYFR dcyfr-ai-agents Environment — Example
# Copy this file to .env and replace 1Password Vault/Item names with your own.
# Install 1Password CLI: bash scripts/setup-1password.sh
# Format: op://<Vault>/<Item>/<Field>

# ─── Secrets (1Password References) ────────────────────────────────────────
OPENAI_API_KEY="op://<YourVault>/OpenAI/api_key"

# ─── Configuration ─────────────────────────────────────────────────────────
OPENAI_API_BASE=
VECTOR_DB_PROVIDER=
VECTOR_DB_URL=
VECTOR_DB_INDEX=
LLM_PROVIDER=
LLM_MODEL=
LLM_EMBEDDING_MODEL=
TELEMETRY_ENABLED=
TELEMETRY_STORAGE=
DCYFR_AGENTS_VERSION=
NODE_ENV=
RESEARCH_MAX_DEPTH=
CS_RESPONSE_TIMEOUT=
CODEGEN_TARGET=
