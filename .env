# DCYFR dcyfr-ai-agents Environment
# Secrets use 1Password references (op:// URLs).
# Run commands with: op run -- npm start
# Setup: bash scripts/setup-1password.sh
# Migration: node scripts/migrate-to-1password.mjs

# ─── Secrets (resolved at runtime by 1Password CLI) ────────────────────────
OPENAI_API_KEY="op://Development/OpenAI/api_key"

# ─── Configuration (non-sensitive) ─────────────────────────────────────────
OPENAI_API_BASE=http://localhost:8317/v1
VECTOR_DB_PROVIDER=qdrant
VECTOR_DB_URL=http://localhost:6333
VECTOR_DB_INDEX=dcyfr_memories
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
LLM_EMBEDDING_MODEL=text-embedding-3-small
TELEMETRY_ENABLED=true
TELEMETRY_STORAGE=sqlite
DCYFR_AGENTS_VERSION=1.0.0
NODE_ENV=development
RESEARCH_MAX_DEPTH=5
CS_RESPONSE_TIMEOUT=30000
CODEGEN_TARGET=typescript
