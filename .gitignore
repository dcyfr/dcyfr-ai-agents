# Environment
# Never commit real .env files
.env
**/.env
.env.*
**/.env.*

# Keep safe templates/examples tracked
!.env.example
!**/.env.example
!.env.ci
!**/.env.ci

# .env.local contains plaintext secrets — NEVER commit
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Memory storage (long-term memory files)
*.memory.json
agent-memory.json
research-agent-memory.json

# Temporary
tmp/
temp/
*.tmp

